    rx = targ.r(1,:); 
    ry = targ.r(2,:); 
    
    nx = targ.n(1,:); 
    ny = targ.n(2,:);
    
    dx = targ.d(1,:);
    dy = targ.d(2,:);
    
    ds = sqrt(dx.*dx+dy.*dy);
    taux = (dx./ds); % normalization
    tauy = (dy./ds);
    
    targs = zeros(13,length(targ.r(1,:)));
    targs(1:2,:) = [rx; ry];
    targs(4:5,:) = [taux; tauy];
    targs(10:11,:) = [nx; ny];
    targs(13,:) = targ.kappa(:);

    [ndtarg,ntarg] = size(targs);
    ntp1 = ntarg+1;

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    %   compute near quadrature correction

    wnear = zeros(2,nquad,'like',1i);

    # FORTRAN getnearquad_flex_bcs(int[1] npatches, int[npatches] norders, int[npp1] ixyzs, int[npatches] iptype, int[1] npts, double[n9,npts] srccoefs, double[n12,npts] srcvals, int[1] ndtarg, int[1] ntarg, double[ndtarg,ntarg] targs, int[ntarg] ipatch_id, double[2,ntarg] uvs_targ, double[1] eps, dcomplex[13] zpars, int[1] iquadtype, int[1] nnz, int[ntp1] row_ptr, int[nnz] col_ind, int[nnzp1] iquad, double[1] rfac0, int[1] nquad, inout dcomplex[2,nquad] wnear);


end


