function wnear = getnearquad_v2b_flex(npatches,norders,ixyzs, ...
          iptype,npts,srccoefs,srcvals,targ,ipatch_id, uvs_targ, eps,...
            iquadtype,nnz, ...
          row_ptr,col_ind,iquad,rfac0,zpars,nquad)
